    {
      "parameters": {
        "jsCode": "const rawText = $input.first().json.output;\n\nconst jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n\nif (jsonMatch) {\n  try {\n    const parsed = JSON.parse(jsonMatch[0]);\n    return {\n      name: parsed.name || \"N/A\",\n      email: parsed.email || \"N/A\",\n      phone: parsed.phone || \"N/A\"\n    };\n  } catch (e) {\n    return { name: \"Parse Error\", email: \"\", phone: \"\", raw: rawText };\n  }\n}\n\nreturn { name: \"No JSON Found\", email: \"\", phone: \"\", raw: rawText };"
      },
