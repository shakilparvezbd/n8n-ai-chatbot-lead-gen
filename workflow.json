    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst setData = items.find(i => i.json.sessionId && i.json.chatInput);\nif (!setData) {\n  return { error: \"Set data not found\" };\n}\n\nconst sessionId = setData.json.sessionId;\nconst chatInput = setData.json.chatInput;\n\nconst staticData = $getWorkflowStaticData('global');\n\nif (!staticData.sessions) {\n  staticData.sessions = {};\n}\n\nconst session = staticData.sessions[sessionId] || [];\nconst recentMessages = session.slice(-20);\nconst chatHistory = recentMessages.map(m => m.role + \": \" + m.content).join(\"\\n\");\n\nreturn {\n  sessionId: sessionId,\n  chatInput: chatInput,\n  chatHistory: chatHistory,\n  allMessages: session,\n  debugSessionLength: session.length,\n  debugTotalSessions: Object.keys(staticData.sessions).length,\n  debugAllKeys: Object.keys(staticData.sessions)\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -976,
        -768
      ],
      "id": "bfa1a6b3-8e22-4584-be24-77359a88a101",
      "name": "Load Memory"
    },
    {
      "parameters": {
        "jsCode": "const loadMemoryData = $('Load Memory').first().json;\nconst sessionId = loadMemoryData.sessionId;\nconst chatInput = loadMemoryData.chatInput;\n\nconst allRows = $input.all();\n\nlet sessionMessages = \"\";\n\nif (allRows.length > 0) {\n  sessionMessages = allRows\n    .filter(row => String(row.json.sessionId) === String(sessionId))\n    .sort((a, b) => new Date(a.json.timestamp) - new Date(b.json.timestamp))\n    .slice(-20)\n    .map(row => row.json.role + \": \" + row.json.content)\n    .join(\"\\n\");\n}\n\nreturn {\n  sessionId: sessionId,\n  chatInput: chatInput,\n  chatHistory: sessionMessages\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
